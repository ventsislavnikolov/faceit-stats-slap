{
  "name": "faceit-stats-slap",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "sideEffects": false,
  "scripts": {
    "prepare": "husky",
    "dev": "vite dev",
    "test": "vitest run",
    "build": "vite build",
    "fix": "ultracite fix",
    "test:watch": "vitest",
    "check": "ultracite check",
    "test:e2e": "playwright test",
    "start": "node .output/server/index.mjs",
    "test:coverage": "vitest run --coverage",
    "test:e2e:coverage:report": "node scripts/e2e-coverage-report.mjs",
    "test:e2e:coverage:clean": "rm -rf coverage/e2e coverage/e2e-report",
    "test:coverage:all": "vitest run --coverage && pnpm test:e2e:coverage",
    "test:e2e:coverage": "playwright test --project=chromium && node scripts/e2e-coverage-report.mjs"
  },
  "dependencies": {
    "@laihoe/demoparser2": "^0.41.3",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "1.168.13",
    "@tanstack/react-start": "1.167.20",
    "fzstd": "^0.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "nitro": "3.0.260610-beta",
