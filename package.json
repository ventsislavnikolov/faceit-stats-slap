{
  "name": "faceit-stats-slap",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.0",
  "sideEffects": false,
  "scripts": {
    "prepare": "husky",
    "dev": "vite dev",
    "test": "vitest run",
    "build": "vite build",
    "fix": "ultracite fix",
    "test:watch": "vitest",
    "check": "ultracite check",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "playwright test --project=chromium && node scripts/e2e-coverage-report.mjs",
    "test:e2e:coverage:report": "node scripts/e2e-coverage-report.mjs",
    "test:e2e:coverage:clean": "rm -rf coverage/e2e coverage/e2e-report",
    "start": "node .output/server/index.mjs",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "vitest run --coverage && pnpm test:e2e:coverage"
  },
  "dependencies": {
    "@laihoe/demoparser2": "^0.41.1",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.7",
    "@tanstack/react-start": "^1.167.16",
    "fzstd": "^0.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "nitro": "3.0.260311-beta",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "ultracite": "7.3.2",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "version": "1.7.3"
}
